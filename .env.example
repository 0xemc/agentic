# NanoClaw adapter toggle
NEXT_PUBLIC_NANOCLAW_ENABLED=true

# Path to the NanoClaw SQLite messages database
NANOCLAW_DB_PATH=/path/to/nanoclaw/store/messages.db

# Path to the NanoClaw groups directory
NANOCLAW_GROUPS_PATH=/path/to/nanoclaw/groups

# Path to the NanoClaw IPC directory (for available_groups.json and task files)
NANOCLAW_IPC_PATH=/path/to/nanoclaw/ipc

# How often (ms) to poll for new messages
NANOCLAW_POLL_INTERVAL=5000

# Mock adapter toggle (used for development without NanoClaw)
NEXT_PUBLIC_MOCK_ENABLED=false
